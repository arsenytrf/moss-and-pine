<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 600" preserveAspectRatio="xMidYMid slice">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#2D4A3E"/>
      <stop offset="100%" stop-color="#1F362D"/>
    </linearGradient>
    <pattern id="p" width="40" height="40" patternUnits="userSpaceOnUse">
      <circle cx="20" cy="20" r="1.5" fill="#C0653D" opacity="0.25"/>
    </pattern>
  </defs>
  <rect width="800" height="600" fill="url(#bg)"/>
  <rect width="800" height="600" fill="url(#p)"/>
  <g transform="translate(400,300)">
    <circle r="60" fill="none" stroke="#FAF5E9" stroke-width="2" opacity="0.35"/>
    <path d="M-25 0 L-10 15 L25 -20" stroke="#EBA87C" stroke-width="4" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
  </g>
  <text x="400" y="420" font-family="Georgia, serif" font-size="18" fill="#FAF5E9" text-anchor="middle" opacity="0.7" font-style="italic">Moss &amp; Pine · placeholder</text>
</svg>
